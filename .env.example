# ── Active provider ────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to either "lm_studio" or "ollama" — only one is active at a time.
LLM_PROVIDER=lm_studio

# ── LM Studio (active when LLM_PROVIDER=lm_studio) ────────────────────────────
LM_STUDIO_URL=http://localhost:1234/v1
LM_STUDIO_TEXT_MODEL=google/gemma-4-26b-a4b    # text / code model
LM_STUDIO_VISION_MODEL=google/gemma-4-26b-a4b # multimodal model

# ── Ollama (active when LLM_PROVIDER=ollama) ───────────────────────────────────
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_TEXT_MODEL=gemma4:26b
OLLAMA_VISION_MODEL=gemma4:26b

# ── Optional ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO    # DEBUG | INFO | WARNING | ERROR
