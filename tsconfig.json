{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": ["tests/**/*", "playwright.config.ts", "src/**/*"],
  "exclude": ["node_modules", "dist", "tests/fixtures", ".venv"]
}
